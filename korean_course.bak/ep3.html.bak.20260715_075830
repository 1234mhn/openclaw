function openLesson(n){
  document.querySelectorAll('.pg').forEach(function(p){p.classList.remove('show')});
  var pg=document.getElementById('pageLesson'+n);
  if(!pg)return;
  pg.classList.add('show');
  // 动态注入视频（首次打开时才创建）
  if(!pg.querySelector('video')){
    var d=LESSONS[n];
    if(d&&d.video){
      var wrap=document.createElement('div');
      wrap.className='video-wrap';
      var v=document.createElement('video');
      v.controls=true;
      v.preload='auto';
      v.src=d.video;
      // 添加字幕轨道
      if(d.subtitle){
        var tr=document.createElement('track');
        tr.kind='subtitles';
        tr.label='韩文';
        tr.srclang='ko';
        tr.src=d.subtitle;
        tr.default=true;
        v.appendChild(tr);
      }
      wrap.appendChild(v);
      var top=pg.querySelector('.top');
      top.parentNode.insertBefore(wrap,top.nextSibling);
      // 确保字幕轨道默认显示
      var tryShowSubs=function(){
        if(v.textTracks&&v.textTracks.length&&v.textTracks[0].mode!=='showing'){
          v.textTracks[0].mode='showing';
        }
      };
      tryShowSubs();
      v.addEventListener('loadedmetadata',tryShowSubs);
      v.addEventListener('loadeddata',tryShowSubs);
    }
  }
  setupTimeSync(n);
}

