<!DOCTYPE html>
<!-- v20260709-ep3 -->
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>第3集 · 新剧情 · 韩语学习系统</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,sans-serif;background:#f0f2f5;color:#333;transition:background .3s,color .3s}
body.dark{background:#0d1117;color:#c9d1d9}
.banner{background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460);color:#fff;padding:30px 20px 24px;text-align:center;position:relative}
.banner h1{font-size:22px;font-weight:700;margin-bottom:2px;letter-spacing:1px}
.banner .sub{font-size:12px;opacity:.55;margin-bottom:10px}
.banner .stats{display:flex;justify-content:center;gap:20px;margin:8px 0}
.banner .stats .item{text-align:center}
.banner .stats .num{font-size:18px;font-weight:700}
.banner .stats .lbl{font-size:10px;opacity:.6;margin-top:1px}
.banner .bar-wrap{max-width:280px;margin:8px auto 0;height:4px;background:rgba(255,255,255,.15);border-radius:2px;overflow:hidden}
.banner .bar{height:100%;width:0;background:linear-gradient(90deg,#2ecc71,#38f9d7);border-radius:2px;transition:width .5s}
.theme-toggle{position:absolute;top:14px;right:16px;background:rgba(255,255,255,.15);border:none;color:#fff;font-size:16px;width:34px;height:34px;border-radius:50%;cursor:pointer;transition:background .2s}
.theme-toggle:hover{background:rgba(255,255,255,.3)}
.container{max-width:700px;margin:0 auto;padding:12px}
.card{background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.06);margin:0 auto;max-width:640px}
body.dark .card{background:#161b22;box-shadow:0 4px 20px rgba(0,0,0,0.4)}
.ep-header{display:flex;align-items:center;padding:14px 18px;border-bottom:1px solid #eee;font-size:15px;font-weight:600;cursor:pointer;user-select:none}
.ep-header.open .ep-arrow{transform:rotate(90deg)}
.ep-content{display:none}
.ep-content.open{display:block}
body.dark .ep-header{border-bottom-color:#30363d}
.ep-header .icon{font-size:18px;margin-right:8px}
.lesson{display:flex;align-items:center;padding:13px 18px;border-bottom:1px solid #f5f5f5;cursor:pointer;text-decoration:none;color:#333;transition:all .3s cubic-bezier(.4,0,.2,1);position:relative;z-index:1}
body.dark .lesson{color:#c9d1d9;border-bottom-color:#21262d}
.lesson:last-child{border-bottom:none}
.lesson:hover{transform:scale(1.03);box-shadow:0 0 20px rgba(52,152,219,0.3);background:#fff;border-radius:10px;z-index:2;margin:2px 4px}
body.dark .lesson:hover{background:#1c2128}
.num{width:28px;height:28px;border-radius:50%;text-align:center;line-height:28px;font-size:12px;font-weight:600;margin-right:14px;flex-shrink:0}
.num.green{background:#2ecc71;color:#fff}
.num.red{background:#e74c3c;color:#fff}
.info{flex:1}
.info .title{font-size:14px;font-weight:500}
.info .sub{font-size:12px;color:#999;margin-top:2px}
.tag{font-size:11px;padding:2px 10px;border-radius:20px;white-space:nowrap;margin-left:8px}
.tag.green{background:#e8f8e8;color:#27ae60}
.tag.red{background:#fde8e8;color:#e74c3c}
.locked{opacity:.45;cursor:default}
.locked:hover{background:transparent;transform:none;box-shadow:none;margin:0}
.pg{display:none;min-height:100vh;background:#fff}
.pg .video-wrap{position:sticky;top:40px;z-index:5;background:#000}
.pg video{width:100%;display:block;background:#000}
body.dark .pg{background:#0d1117}
.pg.show{display:block}
.top{display:flex;align-items:center;padding:6px 16px;border-bottom:1px solid #eee;position:sticky;top:0;background:#fff;z-index:10}
body.dark .top{background:#0d1117;border-bottom-color:#30363d}
.top .back{color:#3498db;font-size:14px;cursor:pointer;margin-right:12px}
.top h2{font-size:16px;font-weight:500;flex:1}
.top .quiz-btn{font-size:12px;padding:6px 14px;border-radius:20px;border:1px solid #3498db;color:#3498db;background:none;cursor:pointer;transition:all .2s}
.top .quiz-btn.active{background:#3498db;color:#fff}
video::cue{bottom:20px !important;background:rgba(0,0,0,.7);color:#fff;font-size:1.1em}
.content{padding:20px;max-width:700px;margin:0 auto}
.sec{font-size:14px;font-weight:600;margin:16px 0 8px;color:#444}
body.dark .sec{color:#8b949e}
.line{display:flex;align-items:flex-start;gap:8px;margin:4px 0 2px 0;cursor:pointer;transition:background .2s,border-color .2s}
.line.active{background:linear-gradient(90deg,rgba(255,193,7,0.12),transparent);border-left:3px solid #f39c12;padding-left:11px;border-radius:0 6px 6px 0}
body.dark .line.active{background:linear-gradient(90deg,rgba(255,193,7,0.08),transparent)}
.kr{font-weight:600;font-size:15px;flex:1}
.speak{background:none;border:none;cursor:pointer;font-size:15px;opacity:.5;transition:opacity .2s;flex-shrink:0;padding:2px}
.speak:hover{opacity:1}
.cn{color:#666;margin:0 0 6px 14px;font-size:14px;transition:.2s}
body.dark .cn{color:#8b949e}
.quiz-on .cn{filter:blur(5px);cursor:pointer;user-select:none}
.quiz-on .cn.revealed{filter:none;cursor:default}
.vocab{font-size:14px;margin:3px 0 3px 10px;color:#444}
body.dark .vocab{color:#adbac7}
.tip{font-size:13px;color:#666;margin:6px 0 0 10px;line-height:1.7}
body.dark .tip{color:#8b949e}
.note-box{width:100%;min-height:90px;border:1px solid #ddd;border-radius:8px;padding:12px;font-size:14px;margin:10px 0;resize:vertical;font-family:inherit;background:#fff;color:#333}
body.dark .note-box{background:#161b22;border-color:#30363d;color:#c9d1d9}
.note-status{font-size:11px;color:#2ecc71;margin-left:4px;opacity:0;transition:opacity .3s}
.note-status.show{opacity:1}
.line-hd{cursor:pointer;display:flex;align-items:center;gap:6px;padding:6px 0;user-select:none}
.line:has(.line-hd){display:block;margin:4px 0 2px 0}
.line-hd .arr{transition:transform .2s;font-size:12px;color:#999;flex-shrink:0}
.line-hd .arr.open{transform:rotate(90deg)}
.line-exp{padding:10px 14px;background:#f8f9fb;border-radius:10px;margin:0 0 8px 0;display:none;border-left:3px solid #3498db}
.line-exp .item{margin:6px 0;font-size:13px}
.line-exp .item b{color:#333}
.line-exp .item .m{color:#666}
.line-exp .ex{color:#555;margin:2px 0 0 14px;font-size:12px;border-left:2px solid #ddd;padding-left:8px}
.line-exp .ex .c{color:#999}
.line-exp .phon{background:#eef4fa;padding:10px 12px;border-radius:6px;margin:6px 0;font-size:13px;line-height:1.7}
.line-exp .phon b{display:block;margin-bottom:2px}
.done-toggle{display:block;width:100%;padding:12px;margin:14px 0;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;background:#2ecc71;color:#fff;transition:.2s}
.done-toggle.undone{background:#eee;color:#888}
body.dark .done-toggle.undone{background:#21262d;color:#8b949e}
.footer{text-align:center;padding:24px;color:#ccc;font-size:11px}

/* 口语练习样式 */
.speak-practice-toggle{display:block;width:100%;padding:14px;margin:16px 0;border:none;border-radius:12px;font-size:15px;font-weight:600;cursor:pointer;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;box-shadow:0 4px 16px rgba(102,126,234,.3);transition:transform .2s,box-shadow .2s}
.speak-practice-toggle:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(102,126,234,.4)}
.practice-panel{display:none;margin:16px 0;padding:20px;background:#f8f9fc;border-radius:14px;border:1px solid #e8ecf0}
body.dark .practice-panel{background:#1c2128;border-color:#30363d}
.practice-panel.active{display:block}
.practice-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.practice-header h3{font-size:16px;font-weight:600}
.practice-close{background:none;border:none;font-size:20px;cursor:pointer;color:#999;padding:4px 8px;border-radius:6px;transition:background .2s}
.practice-close:hover{background:rgba(0,0,0,.05)}
body.dark .practice-close:hover{background:rgba(255,255,255,.1)}
.practice-mode-selector{display:flex;gap:12px;margin-bottom:16px}
.practice-mode-btn{flex:1;padding:18px 10px;border-radius:14px;font-size:14px;font-weight:600;cursor:pointer;border:1px solid #ddd;background:#fff;color:#555;transition:all .2s;text-align:center;line-height:1.6;min-height:44px}
body.dark .practice-mode-btn{background:#161b22;border-color:#30363d;color:#adbac7}
.practice-mode-btn:hover{border-color:#667eea;transform:translateY(-2px);box-shadow:0 4px 12px rgba(102,126,234,.2)}
.practice-mode-btn .mode-icon{font-size:28px;display:block;margin-bottom:4px}
.practice-question{text-align:center;padding:20px 0}
.practice-question .prompt{font-size:14px;color:#888;margin-bottom:8px}
body.dark .practice-question .prompt{color:#8b949e}
.practice-question .display-text{font-size:26px;font-weight:700;margin:12px 0;line-height:1.4}
.practice-question .display-text.ko{color:#3498db}
.practice-question .display-text.cn{color:#e67e22}
.practice-controls{display:flex;justify-content:center;gap:12px;margin:16px 0}
.practice-record-btn{width:64px;height:64px;border-radius:50%;border:3px solid #667eea;background:#fff;font-size:28px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center}
body.dark .practice-record-btn{background:#161b22}
.practice-record-btn:hover{background:#f0f0ff;transform:scale(1.05)}
body.dark .practice-record-btn:hover{background:#1c2128}
.practice-record-btn.recording{background:#e74c3c;border-color:#e74c3c;color:#fff;animation:pulse 1s infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(231,76,60,.4)}50%{box-shadow:0 0 0 12px rgba(231,76,60,0)}}
.practice-record-btn:disabled{opacity:.4;cursor:not-allowed}
.practice-result{margin:16px 0;padding:16px;border-radius:10px;background:#fff;border:1px solid #e8ecf0}
body.dark .practice-result{background:#0d1117;border-color:#30363d}
.practice-result .user-text{font-size:15px;font-weight:500;margin:6px 0;text-align:center}
.practice-result .expected-text{font-size:14px;color:#888;margin:4px 0;text-align:center}
body.dark .practice-result .expected-text{color:#8b949e}
.practice-word-analysis{margin:10px 0;display:flex;flex-wrap:wrap;gap:6px;justify-content:center}
.practice-word-analysis .word-chip{padding:4px 10px;border-radius:6px;font-size:14px;font-weight:500}
.practice-word-analysis .word-chip.correct{background:#e8f8e8;color:#27ae60}
body.dark .practice-word-analysis .word-chip.correct{background:#0f2e1a;color:#3fb950}
.practice-word-analysis .word-chip.wrong{background:#fde8e8;color:#e74c3c}
body.dark .practice-word-analysis .word-chip.wrong{background:#2e1414;color:#f85149}
.practice-word-analysis .word-chip.missing{background:#fef3e2;color:#e67e22}
body.dark .practice-word-analysis .word-chip.missing{background:#2e2014;color:#d49433}

/* 口语练习 - 打字输入模式 */
.practice-type-area{display:flex;gap:8px;justify-content:center;align-items:center;margin:12px 0}
.practice-type-input{flex:1;max-width:300px;padding:10px 14px;border:2px solid #ddd;border-radius:10px;font-size:16px;outline:none;transition:border-color .3s}
.practice-type-input:focus{border-color:#667eea}
.practice-type-btn{padding:10px 20px;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff}
.practice-rec-btn{width:80px;height:80px;border-radius:50%;border:3px solid #667eea;background:#fff;font-size:28px;cursor:pointer;transition:transform .2s,box-shadow .2s;display:flex;align-items:center;justify-content:center;margin:0 auto}
.practice-rec-btn:hover{transform:scale(1.05);box-shadow:0 4px 16px rgba(102,126,234,.3)}
.practice-rec-btn.recording{background:#e74c3c;border-color:#c0392b;animation:pulse2 1s infinite}
.practice-score-display{font-size:14px;color:#666;margin:4px 0}
.practice-target{font-size:20px;font-weight:600;margin:10px 0;padding:8px;background:#f8f9fa;border-radius:8px}
body.dark .practice-target{background:#1c2128;color:#c9d1d9}
.practice-prompt{font-size:14px;color:#888;margin-top:10px}
@keyframes pulse2{0%{transform:scale(1)}50%{transform:scale(1.08)}100%{transform:scale(1)}}

.practice-status-msg{text-align:center;font-size:13px;color:#888;margin:8px 0}
body.dark .practice-status-msg{color:#8b949e}
.practice-next-btn{display:block;margin:16px auto 0;padding:10px 32px;border:none;border-radius:20px;background:#3498db;color:#fff;font-size:14px;cursor:pointer;transition:background .2s}
.practice-next-btn:hover{background:#2980b9}
.practice-score{display:flex;justify-content:center;gap:24px;margin:12px 0;font-size:13px;color:#888}
body.dark .practice-score{color:#8b949e}
.practice-score .score-item{text-align:center}
.practice-score .score-num{font-size:20px;font-weight:700;color:#333}
body.dark .practice-score .score-num{color:#c9d1d9}
.practice-summary{text-align:center;padding:20px}
.practice-summary .big-icon{font-size:48px;margin-bottom:12px}
.practice-summary .score-display{font-size:24px;font-weight:700;margin:8px 0}
.practice-summary .detail-text{font-size:14px;color:#888;margin:4px 0}
.accuracy-bar{height:6px;border-radius:3px;background:#eee;margin:10px 0;overflow:hidden}
body.dark .accuracy-bar{background:#21262d}
.accuracy-fill{height:100%;border-radius:3px;transition:width .5s}
.accuracy-label{font-size:12px;text-align:center;color:#888;margin-top:4px}

/* 口语练习 - 全屏模态覆盖层 */
.practice-modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;z-index:10000;background:linear-gradient(135deg,#667eea,#764ba2);overflow-y:auto}
.practice-modal.active{display:block}
.practice-modal-inner{min-height:100vh;display:flex;flex-direction:column;max-width:700px;margin:0 auto;width:100%;padding:0}
.practice-modal-header{display:flex;align-items:center;padding:16px 20px;color:#fff;position:sticky;top:0;z-index:10;background:linear-gradient(135deg,#667eea,#764ba2)}
.practice-modal-header .back-btn{background:rgba(255,255,255,.15);border:none;color:#fff;font-size:20px;width:36px;height:36px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;margin-right:12px;transition:background .2s;flex-shrink:0}
.practice-modal-header .back-btn:hover{background:rgba(255,255,255,.3)}
.practice-modal-header h3{font-size:17px;font-weight:600;flex:1;text-align:center;margin-right:36px}
.practice-modal-body{flex:1;background:#fff;border-radius:16px 16px 0 0;padding:24px 20px;min-height:80vh}
body.dark .practice-modal-body{background:#0d1117;color:#c9d1d9}

/* ===== 桌面端适配 ===== */
</style>
</head>
<body>

<div class="pg show" id="pageIndex">
<div class="banner">
<button class="theme-toggle" onclick="toggleTheme()" id="themeBtn" title="切换深色模式">🌙</button>
<h1>📺 第3集 · 新剧情</h1>
<div class="sub">这爱情怎么翻译 · 12集 / 1课</div>
<div class="stats">
<div class="item"><div class="num" style="color:#2ecc71;" id="statDone">0</div><div class="lbl">已学</div></div>
<div class="item"><div class="num" style="color:#e74c3c;" id="statTodo">0</div><div class="lbl">待学</div></div>
<div class="item"><div class="num" style="color:#fff;">12</div><div class="lbl">总集数</div></div>
<div class="item"><div class="num" style="color:#f39c12;">1</div><div class="lbl">总课数</div></div>
</div>
<div class="bar-wrap"><div class="bar" id="progBar"></div></div>
<div style="font-size:11px;opacity:.5;margin-top:6px;">🎬 新课程持续更新中</div>
</div>
<div class="container">
<div class="card">
<div class="ep-header" onclick="window.location.href='index.html'">
  <span class="icon">🏠</span> 返回首页
  <span class="ep-arrow" style="margin-left:auto;font-size:12px;">◀</span>
</div>
<div class="ep-content open">
<div class="lesson" data-lesson="21" onclick="openLesson(21)">
  <span class="num red">21</span>
  <div class="info">
    <div class="title">第21课 · 症状を伝える</div>
    <div class="sub">병원에서의 대화</div>
  </div>
  <span class="tag red">待学</span>
</div>
</div>
</div>
</div>
</div>

<script>
var TOTAL_LESSONS=1,UNLOCKED=[];

/* ---------- 课程数据（待补充） ---------- */
var LESSONS={};
LESSONS[21]={
  title:'第21课 · 症状を伝える',
  video:'videos/ep03_l21.mp4',
  vocab:[
    ['불안하다','不安 (anxious)'],
    ['꾀병','装病 (faking illness)'],
    ['어지럽다','头晕 (dizzy)'],
    ['덜덜 떨리다','瑟瑟发抖 (tremble)'],
    ['뒤집어지다','翻转 (turn over)'],
    ['열이 나다','发烧 (have a fever)'],
    ['쓰러지다','倒下 (collapse)'],
    ['갖다 대다','贴上 (put against)'],
    ['장난','玩笑 (joke)'],
    ['통역하다','翻译 (interpret)'],
    ['입원','住院 (hospitalization)'],
    ['당장','立刻 (immediately)'],
    ['그대로','原样 (as is)'],
    ['행사','活动 (event)'],
    ['병원','医院 (hospital)']
  ],
  lines:[
    '불안한 거 말고는 뭐, 어디 다른 데 아픈 데는 없어요?',
    '뭐, 꾀병일까 봐요?',
    '어지럽고 덜덜 떨리고, 속도 뒤집어질 거 같고',
    '열도 나고 쓰러질 거 같거든요?',
    '갖다 대 봐요, 진짜 열나나',
    '왜 이래요?',
    '차무희 씨, 여기 병원이에요',
    '내가 들은 그대로 믿고 통역하면',
    '당신 행사고 뭐고 못 가고, 당장 입원입니다',
    '장난하지 마요'
  ],
  subtitle:''
};

/* ---------- 音频映射表 ---------- */
var KO_AUDIO_MAP={};

var STORE_KEY='korean_done_ep3';
var NOTE_STORE_KEY='korean_notes_ep3';
var SPEECH_KEY='korean_speech_ep3';

function openLesson(n){
  document.querySelectorAll('.pg').forEach(function(p){p.classList.remove('show')});
  var pg=document.getElementById('pageLesson'+n);
  if(pg){pg.classList.add('show');setupTimeSync(n);}
}

function toggleExp(el){
  var arr=el.querySelector('.arr'),exp=el.parentElement.querySelector('.line-exp');
  if(exp.style.display==='block'){exp.style.display='none';arr.classList.remove('open')}
  else{exp.style.display='block';arr.classList.add('open')}
}

function goHome(){
  document.querySelectorAll('video').forEach(function(v){v.pause()});
  document.querySelectorAll('.pg').forEach(function(p){p.classList.remove('show')});
  document.getElementById('pageIndex').classList.add('show');
  refreshProgress();
}

function handleSpeak(e,text){
  e.stopPropagation();
  speak(text);
}

function speak(text){
  var audioFile=KO_AUDIO_MAP[text];
  if(audioFile){
    var a=new Audio('audio/'+audioFile);
    a.play().catch(function(e){console.warn('音频播放失败, 尝试浏览器TTS:',e);speakFallback(text)});
  }else{
    speakFallback(text);
  }
}

function speakFallback(text){
  if(!window.speechSynthesis)return;
  var u=new SpeechSynthesisUtterance(text);
  u.lang='ko-KR';u.rate=0.8;
  var v=speechSynthesis.getVoices().filter(function(x){return x.lang.indexOf('ko')===0});
  if(v.length)u.voice=v[0];
  speechSynthesis.speak(u);
}

function toggleQuiz(n){
  var c=document.getElementById('content'+n),btn=event.target;
  var on=c.classList.toggle('quiz-on');btn.classList.toggle('active',on);
  c.querySelectorAll('.cn').forEach(function(el){
    if(on)el.onclick=function(){el.classList.add('revealed')};else el.onclick=null;
  });
}

document.querySelectorAll('.note-box').forEach(function(box){
  var n=box.dataset.note;
  if(!n)return;
  var saved=localStorage.getItem(NOTE_STORE_KEY+'_'+n);
  if(saved)box.value=saved;
  box.addEventListener('input',function(){
    localStorage.setItem(NOTE_STORE_KEY+'_'+n,this.value);
    var st=document.getElementById('noteStatus'+n);
    if(st){st.classList.add('show');clearTimeout(st._timer);st._timer=setTimeout(function(){st.classList.remove('show')},1500);}
  });
});

function saveNote(n){
  var box=document.querySelector('.note-box[data-note="'+n+'"]');
  if(box)localStorage.setItem(NOTE_STORE_KEY+'_'+n,box.value);
}

function loadNote(n){
  var saved=localStorage.getItem(NOTE_STORE_KEY+'_'+n);
  if(saved){var box=document.querySelector('.note-box[data-note="'+n+'"]');if(box)box.value=saved;}
}

function loadDone(){
  try{var d=JSON.parse(localStorage.getItem(STORE_KEY));return Array.isArray(d)?d:[]}catch(e){return[]}
}

function saveDone(n,done){
  var arr=loadDone();
  if(done){if(arr.indexOf(n)<0)arr.push(n)}else{arr=arr.filter(function(x){return x!==n})}
  localStorage.setItem(STORE_KEY,JSON.stringify(arr));
  refreshProgress();
}

function toggleDone(n){
  var btn=document.querySelector('.done-toggle[data-lesson="'+n+'"]');if(!btn)return;
  var done=btn.classList.toggle('undone');btn.textContent=done?'恢复待学':'✓ 已完成学习';
  saveDone(n,!done);
}

function refreshProgress(){
  var doneCount=loadDone().length;
  document.getElementById('statDone').textContent=doneCount;
  document.getElementById('statTodo').textContent=TOTAL_LESSONS-doneCount;
  if(TOTAL_LESSONS>0)document.getElementById('progBar').style.width=(doneCount/TOTAL_LESSONS*100).toFixed(1)+'%';else document.getElementById('progBar').style.width='0%';
}

function toggleTheme(){
  var b=document.body;b.classList.toggle('dark');
  var btn=document.getElementById('themeBtn');
  btn.textContent=b.classList.contains('dark')?'☀️':'🌙';
  localStorage.setItem('darkMode',b.classList.contains('dark')?'1':'0');
}

function toggleEp(el){
  el.classList.toggle('open');
  var content=el.nextElementSibling;
  if(content&&content.classList.contains('ep-content'))content.classList.toggle('open');
}

var darkSaved=localStorage.getItem('darkMode');
if(darkSaved==='1'){document.body.classList.add('dark');document.getElementById('themeBtn').textContent='☀️';}

function toggleVocab(el){
  var arrow=el.querySelector('span');
  var content=el.nextElementSibling;
  if(content.style.display==='none'){
    content.style.display='block';
    arrow.style.transform='rotate(90deg)';
  }else{
    content.style.display='none';
    arrow.style.transform='rotate(0deg)';
  }
}
function toggleGrammar(el){
  var arrow=el.querySelector('span');
  var content=el.nextElementSibling;
  if(content.style.display==='none'){
    content.style.display='block';
    arrow.style.transform='rotate(90deg)';
  }else{
    content.style.display='none';
    arrow.style.transform='rotate(0deg)';
  }
}

document.addEventListener('DOMContentLoaded',function(){refreshProgress()});
document.addEventListener('click',function(e){
  var cn=e.target.closest('.cn');
  if(cn&&cn.closest('.quiz-on'))cn.classList.add('revealed');
});

/* ---------- 口语练习（占位保留） ---------- */
function startPractice(n){
  var l={21:['불안한 거 말고는 뭐, 어디 다른 데 아픈 데는 없어요?','뭐, 꾀병일까 봐요?','어지럽고 덜덜 떨리고, 속도 뒤집어질 거 같고','열도 나고 쓰러질 거 같거든요?','갖다 대 봐요, 진짜 열나나','왜 이래요?','차무희 씨, 여기 병원이에요','내가 들은 그대로 믿고 통역하면','당신 행사고 뭐고 못 가고, 당장 입원입니다','장난하지 마요']};
  var lines=l[n];if(!lines||!lines.length){alert('该课程暂无口语练习内容');return;}
  openPracticeModal(n,lines);
}

/* ---------- 视频与台词联动（占位保留） ---------- */
var LESSON_TIMES={};
LESSON_TIMES[21]=[
  {start:377.085,end:379.003},
  {start:380.880,end:382.423},
  {start:382.924,end:385.176},
  {start:385.259,end:386.344},
  {start:389.806,end:390.848},
  {start:392.433,end:393.851},
  {start:395.353,end:397.063},
  {start:397.730,end:399.732},
  {start:399.816,end:402.151},
  {start:402.693,end:404.612}
];

function setupTimeSync(n){
  var times=LESSON_TIMES[n];
  if(!times)return;
  var content=document.getElementById('content'+n);
  if(!content)return;
  var lines=content.querySelectorAll('.line');
  if(lines.length===0)return;
  var pg=document.getElementById('pageLesson'+n);
  var video=pg?pg.querySelector('video'):null;
  if(!video)return;
  if(video._syncHandler){video.removeEventListener('timeupdate',video._syncHandler)}
  video._syncHandler=function(){
    var ct=video.currentTime,activeIdx=-1;
    for(var i=0;i<times.length;i++){
      if(ct>=times[i].start&&ct<times[i].end){activeIdx=i;break}
    }
    if(activeIdx===lines._activeIdx)return;
    if(typeof lines._activeIdx==='number'&&lines._activeIdx>=0&&lines._activeIdx<lines.length){
      lines[lines._activeIdx].classList.remove('active');
    }
    lines._activeIdx=activeIdx;
    if(activeIdx>=0){
      lines[activeIdx].classList.add('active');
      lines[activeIdx].scrollIntoView({behavior:'smooth',block:'nearest'});
    }
  };
  video.addEventListener('timeupdate',video._syncHandler);
  for(var i=0;i<lines.length;i++){
    (function(idx){
      lines[idx].onclick=function(e){
        if(e.target.classList.contains('speak'))return;
        var t=times[idx];
        if(t){lines[idx].classList.add("active");if(video.readyState>=1){video.currentTime=t.start;video.play()}else{video.addEventListener("loadedmetadata",function h(){video.currentTime=t.start;video.play();video.removeEventListener("loadedmetadata",h)})}}
      }
    })(i)
  }
}
</script>
