}

// ===== PAGE NAVIGATION =====
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => {
    p.classList.remove('active');
    p.style.display = ''; // clear inline display to let CSS cascade handle it
  });
  const page = document.getElementById(id);
  if (page) page.classList.add('active');
}

function pageTransition(fromId, toId, direction) {
  const from = document.getElementById(fromId);
  const to = document.getElementById(toId);
  if (!from || !to) return;

  const outClass = direction === 'right' ? 'slide-out-left' : 'slide-out-right';
  const inClass = direction === 'right' ? 'slide-in-right' : 'slide-in-left';

  // Clear any leftover inline display styles that could cause overlaps
  document.querySelectorAll('.page').forEach(p => p.style.display = '');

  // Both pages keep .active during animation for visibility
  to.classList.add('active', inClass);
  from.classList.add(outClass);

  setTimeout(() => {
    from.classList.remove('active', outClass);
    to.classList.remove(inClass);
  }, 380);
}

function showModulesPage() {
  pageTransition('page-main', 'page-modules', 'right');
  currentPage = 'modules';
}

function goBackToMain() {
  pageTransition('page-modules', 'page-main', 'left');
  currentPage = 'main';
}

function goBackToModules() {
  showPage('page-modules');
  currentPage = 'modules';
}

// ===== MODULE LIST =====
function renderModuleList() {
  const list = document.getElementById('modules-list');
  list.innerHTML = '';
  const icons = ['☀️', '🌡️', '🌧️', '🌬️', '💬', '🌪️', '🔊'];
  for (let i = 1; i <= 7; i++) {
    const m = MODULE_DATA[i];
    if (!m) continue;
    const card = document.createElement('div');
    card.className = 'module-card';
    card.innerHTML = `
      <div class="m-icon" style="background:${m.color}22; color:${m.color}">${icons[i-1]}</div>
      <div class="m-info">
        <div class="m-title">
          ${m.title}
          <span class="m-badge" style="background:${m.color}">${i}/7</span>
        </div>
        <div class="m-desc">${m.desc}</div>
      </div>
      <div class="m-arrow">›</div>
    `;
    card.addEventListener('click', () => openCardLearning(i));
    list.appendChild(card);
  }
}

// ===== CARD LEARNING =====
function openCardLearning(moduleIdx) {
  currentModuleIdx = moduleIdx;
  currentCardIdx = 0;
  const m = MODULE_DATA[moduleIdx];
  document.getElementById('card-page-title').textContent = m.title;
  document.getElementById('card-page-title').style.color = m.color;

  // Set module color class
  const wrapper = document.getElementById('card-wrapper');
  wrapper.className = 'card-wrapper';
  wrapper.classList.add(m.colorClass);

  showPage('page-card');
  currentPage = 'card';
  renderCurrentCard();
}

function renderCurrentCard() {
  const wrapper = document.getElementById('card-wrapper');
  const m = MODULE_DATA[currentModuleIdx];
  const cards = m.cards;
  const total = cards.length;
  const card = cards[currentCardIdx];

  // Update progress
  document.getElementById('card-progress').textContent = `${currentCardIdx + 1}/${total}`;

  if (card.type === 'vocab') {
    document.getElementById('card-type-tag').textContent = '📖 词汇';
    document.getElementById('card-type-tag').style.color = m.color;
    wrapper.innerHTML = buildVocabCard(card);
  } else if (card.type === 'ex') {
    document.getElementById('card-type-tag').textContent = '📝 练习';
    document.getElementById('card-type-tag').style.color = '#E74C3C';
    wrapper.innerHTML = buildExCard(card);
  } else if (card.type === 'rule') {
    document.getElementById('card-type-tag').textContent = '📚 音变规则';
    document.getElementById('card-type-tag').style.color = '#E65100';
    wrapper.innerHTML = buildRuleCard(card);
  } else if (card.type === 'complete') {
    wrapper.innerHTML = buildCompleteCard(m);
    document.getElementById('card-type-tag').textContent = '🎉 完成！';
  }

  // Add flip handler - skip if clicking audio button
  const flipCard = wrapper.querySelector('.big-flip-card');
  if (flipCard && card.type !== 'rule' && card.type !== 'complete') {
    flipCard.addEventListener('click', (e) => {
      if (e.target.closest('.audio-btn') || e.target.closest('.audio-btn-sm')) return;
      flipCard.classList.toggle('flipped');
    });
  }

  // Wire up audio buttons
  wrapper.querySelectorAll('.audio-btn, .audio-btn-sm').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const text = btn.dataset.text || '';
      if (text) {
        console.log('🔊 Playing:', text);
        speakKorean(text);
      }
    });
  });

  // Update nav buttons
  const prevBtn = document.getElementById('prev-card-btn');
  const nextBtn = document.getElementById('next-card-btn');
  prevBtn.disabled = currentCardIdx === 0;
  nextBtn.disabled = false;

  // Show/hide complete actions
  document.getElementById('complete-actions').style.display = 'none';
  document.getElementById('card-nav').style.display = 'flex';

  // Add touch swipe support
  setupTouchSwipe(wrapper);

  // Auto-reset flip when card changes (after animation)
  setTimeout(() => {
    if (flipCard) flipCard.classList.remove('flipped');
  }, 50);
}

function buildVocabCard(card) {
  const krText = card.kr.replace(/<[^>]*>/g, '');
  const exampleText = (card.example || '').replace(/<[^>]*>/g, '');
  const phraseText = (card.phrase || '').replace(/<[^>]*>/g, '');
  const esc = (s) => s.replace(/'/g, "\\'");
  let moreHtml = '';
  if (card.more && card.more.length) {
    moreHtml = '<div class="more-box"><div class="grammar-title">\u270F\uFE0F \u66F4\u591A\u4F8B\u53E5</div><div class="more-list">' +
      card.more.map(s => {
        const parts = s.split('|');
        return '<div class="more-item"><div class="more-kr">' + (parts[0] || '') + '</div><div class="more-cn">' + (parts[1] || '') + '</div></div>';
      }).join('') + '</div></div>';
  }
  return `
    <div class="big-flip-card vocab-card">
      <div class="big-flip-card-inner">
        <div class="big-card-front vocab-card-front">
          <button class="audio-btn" data-text="${esc(krText)}">🔊</button>
          <div class="pron-badge">${card.pron}</div>
          <div class="icon-deco">${card.emoji}</div>
          <div class="kr-large">${card.kr}</div>
          <div class="tap-hint">👆 点击翻转</div>
          <div class="emoji-large">${card.emoji}</div>
        </div>
        <div class="big-card-back vocab-card-back">
          <div class="cn-big">${card.cn}</div>
          <div class="phrase-text">${card.phrase} <button class="audio-btn-sm" data-text="${esc(phraseText)}">🔊</button></div>
          <div class="example-text">${card.example} <button class="audio-btn-sm" data-text="${esc(exampleText)}">🔊</button></div>
          <div class="example-cn">${card.exampleCn || ''}</div>
          ${card.sound ? `<div class="sound-tag">🔊 ${card.sound}</div>` : ''}
          ${card.grammar ? '<div class="grammar-box"><div class="grammar-title">📖 语法讲解</div><div class="grammar-text">' + card.grammar + '</div></div>' : ''}
          ${card.more ? '<div class="more-box"><div class="grammar-title">✏️ 更多例句</div>' + card.more.map(function(s){var p=s.split('|');return '<div class="more-item"><div class="more-kr">'+(p[0]||'')+'</div><div class="more-cn">'+(p[1]||'')+'</div></div>';}).join('') + '</div>' : ''}
          ${card.grammar ? '<div class="grammar-box"><div class="grammar-title">📖 语法讲解</div><div class="grammar-text">' + card.grammar + '</div></div>' : ''}
          ${moreHtml}
        </div>
      </div>
    </div>
  `;
}

function buildExCard(card) {
  return `
    <div class="big-flip-card ex-card">
      <div class="big-flip-card-inner">
        <div class="big-card-front ex-card-front">
          <div class="ex-icon-big">📝</div>
          <div class="ex-label">尝试回答吧 ✨</div>
          <div class="ex-question">${card.question}</div>
          <div class="tap-hint" style="position:absolute; bottom:14px; left:50%; transform:translateX(-50%); font-size:11px; color:#bbb; white-space:nowrap;">👆 点击看答案</div>
        </div>
        <div class="big-card-back ex-card-back">
          <div class="ex-answer-icon">✅</div>
          <div class="ex-answer-label">参考答案</div>
          <div class="ex-answer-text">${card.answer}</div>
          ${card.detail ? `<div class="ex-answer-detail">${card.detail}</div>` : ''}
        </div>
      </div>
    </div>
  `;
}

function buildRuleCard(card) {
  return `
    <div class="big-flip-card rule-display">
      <div class="big-flip-card-inner">
        <div class="big-card-front">
          <div class="rule-big-title">${card.ruleTitle}</div>
          <div class="rule-big-example">${card.ruleExample}</div>
          <div class="rule-big-desc">${card.ruleDesc}</div>
          <div class="rule-big-detail">${card.ruleDetail.replace(/\n/g, '<br>')}</div>
        </div>
        <div class="big-card-back"></div>
      </div>
    </div>
  `;
}

function buildCompleteCard(module) {
  return `
    <div class="big-flip-card complete-card">
      <div class="big-flip-card-inner">
        <div class="big-card-front">
          <div class="complete-icon">🎉</div>
          <div class="complete-title">${module.completeTitle}</div>
          <div class="complete-desc">${module.completeDesc}</div>
          <div class="complete-emoji-row">${module.completeEmoji}</div>
        </div>
        <div class="big-card-back"></div>
      </div>
    </div>
  `;
}

// ===== CARD NAVIGATION =====
function nextCard() {
  if (isAnimating) return;
  const m = MODULE_DATA[currentModuleIdx];
  const total = m.cards.length;
  if (currentCardIdx >= total - 1) return;

  const wrapper = document.getElementById('card-wrapper');
  const current = wrapper.querySelector('.big-flip-card');
  if (current) {
    current.classList.add('slide-left-out');
    isAnimating = true;
    setTimeout(() => {
      currentCardIdx++;
      renderCurrentCard();
      const newCard = wrapper.querySelector('.big-flip-card');
      if (newCard) newCard.classList.add('slide-right-in');
      setTimeout(() => {
        if (newCard) newCard.classList.remove('slide-right-in');
        isAnimating = false;
      }, 300);
    }, 280);
  }
}

function prevCard() {
  if (isAnimating) return;
  if (currentCardIdx <= 0) return;

  const wrapper = document.getElementById('card-wrapper');
  const current = wrapper.querySelector('.big-flip-card');
  if (current) {
    current.classList.add('slide-right-out');
    isAnimating = true;
    setTimeout(() => {
      currentCardIdx--;
      renderCurrentCard();
      const newCard = wrapper.querySelector('.big-flip-card');
      if (newCard) newCard.classList.add('slide-left-in');
      setTimeout(() => {
        if (newCard) newCard.classList.remove('slide-left-in');
        isAnimating = false;
      }, 300);
    }, 280);
  }
}

// ===== TOUCH SWIPE =====
function setupTouchSwipe(wrapper) {
  wrapper.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });

  wrapper.addEventListener('touchend', (e) => {
    const touchEndX = e.changedTouches[0].clientX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      e.preventDefault();
      if (diff > 0) {
        nextCard();
      } else {
        prevCard();
      }
    }
  }, { passive: false });
}

// Re-bind module 7 complete button
function goToModuleAfterComplete(moduleIdx) {
  if (moduleIdx <= 7) {
    openCardLearning(moduleIdx);
  } else {
    // All done, go back to main
    showPage('page-main');
    currentPage = 'main';
  }
}

// Override renderCurrentCard to handle completion
const _origRenderCurrentCard = renderCurrentCard;
const _origNextCard = nextCard;

renderCurrentCard = function() {
  const m = MODULE_DATA[currentModuleIdx];
  const cards = m.cards;
  if (currentCardIdx >= cards.length) {
    showCompletionPage(m);
    return;
  }
  _origRenderCurrentCard();
};

nextCard = function() {
  const m = MODULE_DATA[currentModuleIdx];
  if (currentCardIdx >= m.cards.length - 1) {
    currentCardIdx++;
    showCompletionPage(m);
    return;
  }
  _origNextCard();
};

function showCompletionPage(module) {
  const wrapper = document.getElementById('card-wrapper');
  wrapper.innerHTML = buildCompleteCard(module);
  document.getElementById('card-progress').textContent = `🎉 完成！`;
  document.getElementById('card-type-tag').textContent = '🎊 恭喜！';
  document.getElementById('card-nav').style.display = 'flex';

  const prevBtn = document.getElementById('prev-card-btn');
  const nextBtn = document.getElementById('next-card-btn');
  prevBtn.style.display = 'none';
  nextBtn.style.display = 'none';

  document.getElementById('complete-actions').style.display = 'flex';
  const actions = document.getElementById('complete-actions');
  actions.innerHTML = '';

  const backBtn = document.createElement('button');
  backBtn.className = 'module-complete-btn secondary';
  backBtn.textContent = '返回模块列表';
  backBtn.onclick = goBackToModules;
  actions.appendChild(backBtn);

  if (currentModuleIdx < 7) {
    const nextBtn2 = document.createElement('button');
    nextBtn2.className = 'module-complete-btn';
    nextBtn2.style.background = MODULE_DATA[currentModuleIdx + 1].color;
    nextBtn2.textContent = '进入下一模块 →';
    nextBtn2.onclick = () => openCardLearning(currentModuleIdx + 1);
    actions.appendChild(nextBtn2);
  } else {
    const allDoneBtn = document.createElement('button');
    allDoneBtn.className = 'module-complete-btn';
    allDoneBtn.textContent = '🎉 全部完成！回到主界面';
    allDoneBtn.onclick = () => {
      showPage('page-main');
      currentPage = 'main';
    };
    actions.appendChild(allDoneBtn);
  }
}

// 🔊 韩语语音播放（使用预生成的edge-tts音频，兼容所有浏览器）
const AUDIO_BASE = '/weather_audio/';
let audioMapping = null;
let currentAudio = null;

// 加载音频映射表
fetch(AUDIO_BASE + 'mapping.json')
  .then(r => r.json())
  .then(m => { audioMapping = m; })
  .catch(() => { console.warn('Audio mapping not loaded, will use TTS fallback'); });

function speakKorean(text) {
  if (!text || text.trim() === '') return;
  
  // 按钮视觉反馈
  const btn = document.activeElement;
  if (btn) {
    btn.style.transform = 'scale(0.85)';
    setTimeout(() => { btn.style.transform = ''; }, 200);
  }
  
  // 查找对应的音频文件
  if (audioMapping && audioMapping[text]) {
    if (currentAudio) { currentAudio.pause(); currentAudio = null; }
    const filename = audioMapping[text];
    const audio = new Audio(AUDIO_BASE + encodeURIComponent(filename));
    currentAudio = audio;
    audio.play().catch(() => {
      // 音频播放失败，用浏览器TTS备用
      tryTTS(text);
    });
    return;
  }
  
  // 没有音频文件，用浏览器TTS
  tryTTS(text);
}

function tryTTS(text) {
  try {
    window.speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance(text);
    u.lang = 'ko-KR';
    u.rate = 0.85;
    window.speechSynthesis.speak(u);
  } catch(e) {
    console.warn('TTS fallback failed:', e);
  }
}


</script>
</body>
</html>
